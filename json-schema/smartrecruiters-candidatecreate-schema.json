{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/CandidateCreate",
  "title": "CandidateCreate",
  "type": "object",
  "required": [
    "firstName",
    "lastName",
    "email"
  ],
  "properties": {
    "firstName": {
      "type": "string"
    },
    "lastName": {
      "type": "string"
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "phoneNumber": {
      "type": "string"
    },
    "location": {
      "type": "object",
      "properties": {
        "city": {
          "type": "string"
        },
        "country": {
          "type": "string"
        }
      }
    },
    "web": {
      "type": "object",
      "properties": {
        "linkedIn": {
          "type": "string",
          "format": "uri"
        },
        "portfolio": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "sourceDetails": {
      "$ref": "#/components/schemas/SourceDetails"
    }
  }
}