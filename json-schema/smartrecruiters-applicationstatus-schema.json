{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/ApplicationStatus",
  "title": "ApplicationStatus",
  "type": "object",
  "properties": {
    "candidateId": {
      "type": "string"
    },
    "postingId": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "IN_PROGRESS",
        "REJECTED",
        "OFFERED",
        "HIRED"
      ]
    },
    "reasonForRejection": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        }
      }
    }
  }
}